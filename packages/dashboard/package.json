{
  "name": "@paysentry/dashboard",
  "version": "1.0.0",
  "description": "Agent-readable dashboard — JSON API + SSE events + minimal HTML",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "paysentry-dashboard": "dist/cli.js"
  },
